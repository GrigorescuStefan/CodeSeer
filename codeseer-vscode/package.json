{
  "name": "codeseer",
  "displayName": "CodeSeer",
  "description": "Dockerized SAST scanner for CI/CD and local development",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onViewContainer:codeseer",
    "onView:codeseerView",
    "onCommand:codeseer.scan"
  ],
  "main": "out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeseer.scan",
        "title": "Run CodeSeer Scan"
      }
    ],
    "viewsContainers": {
    "activitybar": [
      {
        "id": "codeseer",
        "title": "CodeSeer",
        "icon": "media/icon.svg"
      }
    ]
  },
  "views": {
    "codeseer": [
      {
        "id": "codeseerView",
        "name": "Scanner",
        "type": "webview"
      }
    ]
  }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
